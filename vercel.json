{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/index.js" },
    { "src": "/css/(.*)", "dest": "/client/css/$1" },
    { "src": "/js/(.*)", "dest": "/client/js/$1" },
    { "src": "/dashboard", "dest": "/client/dashboard.html" },
    { "src": "/guard", "dest": "/client/guard.html" },
    { "src": "/", "dest": "/client/index.html" }
  ]
}
